# ── TR AI Platform environment variables ─────────────────────────────────────
# Copy this to .env for local development (never commit .env to git)

# Thomson Reuters API
TR_AUTH_URL=https://aiplatform.gcs.int.thomsonreuters.com/v1/anthropic/token
WORKSPACE_ID=your_workspace_id_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
OPUS_MODEL=claude-opus-4-20250514

# Pipeline behaviour
USE_LLM=true
LLM_BATCH_SIZE=10
EXTRACT_TABLES=true
EXTRACT_IMAGES=false
APPLY_INLINE_FORMATTING=true
MAX_TOKENS=16000
IMAGE_DPI=300

# RAG
RAG_ENABLED=true
RAG_PERSIST_DIR=/app/data/chroma_db
RAG_N_RULES=12
RAG_N_EXAMPLES=25

# File paths
KEYING_RULES_PATH=/app/data/COMPLETE_KEYING_RULES_UPDATED.txt
VENDOR_SGMS_DIR=/app/data/vendor_sgms

# Validator / HITL
# CORPUS_DIR: folder of matched .sgm + .pdf pairs — required for regression tests only
CORPUS_DIR=/data/your_sgm_pdf_corpus
# DECISIONS_FILE: where HITL reviewer decisions are written (JSONL)
DECISIONS_FILE=/app/data/hitl_decisions.jsonl

# Server
HOST=0.0.0.0
PORT=8501
MAX_UPLOAD_SIZE_MB=50
TEMP_DIR=/tmp/sgml_pipeline
